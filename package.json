{
  "name": "@cpxproject/seeders",
  "version": "1.0.0",
  "description": "Run your seeders like migrations: once, safely, and tracked.",
  "main": "build/index.js",
  "type": "module",
  "types": "./build/index.d.ts",
  "files": [
    "build"
  ],
  "exports": {
    ".": "./build/index.js",
    "./commands": "./build/src/commands/main.js",
    "./configure": "./build/configure.js"
  },
  "scripts": {
    "build": "npm run clean && tsc && npm run index:commands && npm run copy:stubs",
    "clean": "rm -rf build",
    "index:commands": "adonis-kit index build/src/commands",
    "copy:stubs": "mkdir -p build/src/stubs && cp src/stubs/*.stub build/src/stubs/",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^7.8.2",
    "@adonisjs/core": "^6.18.0",
    "@adonisjs/lucid": "^21.6.1",
    "@adonisjs/tsconfig": "^1.4.0",
    "adonis-kit": "^1.1.0",
    "typescript": "~5.8"
  },
  "peerDependencies": {
    "@adonisjs/core": "^6.18.0",
    "@adonisjs/lucid": "^21.6.1"
  },
  "author": "Your Name <your.email@example.com>",
  "license": "MIT",
  "homepage": "https://github.com/your-username/cpx-seeders-adonisjs#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-username/cpx-seeders-adonisjs.git"
  },
  "keywords": [
    "adonisjs",
    "adonisjs-v6",
    "seeders",
    "database",
    "migrations"
  ]
}